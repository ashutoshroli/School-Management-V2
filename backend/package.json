{
  "name": "school-erp-backend",
  "version": "1.0.0",
  "private": true,
  "description": "School ERP Backend - Express.js API Server",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "worker": "ts-node-dev --respawn --transpile-only src/workers/index.ts",
    "worker:start": "node dist/workers/index.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
