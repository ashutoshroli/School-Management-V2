# Database (Neon for trial, Postgres for production)
DATABASE_URL="postgresql://user:password@host:5432/school_erp?schema=public"

# Backend
PORT=5000
NODE_ENV=development
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
NEXT_PUBLIC_APP_NAME="School ERP"

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# SMS Gateway (MSG91/Twilio)
SMS_API_KEY="your-sms-api-key"
SMS_SENDER_ID="SCHLRP"

# WhatsApp (Interakt/Wati)
WHATSAPP_API_KEY="your-whatsapp-api-key"
WHATSAPP_API_URL="https://api.interakt.ai/v1"

# Email (SMTP/SendGrid)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760
