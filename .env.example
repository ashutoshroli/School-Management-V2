# Database (Neon for trial, Postgres for production)
DATABASE_URL="postgresql://user:password@host:5432/school_erp?schema=public"

# Backend
PORT=5000
NODE_ENV=development
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# Frontend URL - used by the backend to build OAuth redirect links and for
# CORS (must match the origin the Next.js app is actually served from).
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
NEXT_PUBLIC_APP_NAME="School ERP"

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
# Set this to the "Secret" shown when you add a webhook endpoint in the
# Razorpay Dashboard (Settings > Webhooks), pointing at
# POST {your-backend-url}/api/fees/razorpay/webhook. Required for the
# webhook handler to verify events actually came from Razorpay - without
# it, the webhook endpoint refuses to process events (fails closed).
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# SMS Gateway (MSG91 by default - see backend/src/services/notification/smsProvider.ts)
SMS_PROVIDER="msg91"
SMS_API_KEY="your-msg91-authkey"
SMS_SENDER_ID="SCHLRP"
# Optional: DLT-registered MSG91 Flow template ID. If unset, falls back
# to a plain-text send (only reliable for MSG91 trial/international
# numbers - Indian production sends require a DLT template).
SMS_TEMPLATE_ID=""
SMS_ROUTE="4"

# WhatsApp Business API (Interakt by default - see whatsappProvider.ts)
WHATSAPP_API_KEY="your-whatsapp-api-key"
WHATSAPP_API_URL="https://api.interakt.ai/v1/public"

# Push Notifications (Firebase Cloud Messaging, HTTP v1 API) - values
# come from the Firebase service-account JSON (Project Settings >
# Service Accounts > Generate new private key).
FCM_PROJECT_ID="your-firebase-project-id"
FCM_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# Paste the private_key field from the service account JSON, with real
# newlines replaced by "\n" (this is unescaped automatically at load
# time - see backend/src/config/index.ts).
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIExampleKeyContentHere\n-----END PRIVATE KEY-----\n"

# Email (SMTP/SendGrid) - used for real email notifications (fee
# payment confirmations, etc). If unset, email sending is skipped and
# the corresponding Notification row is marked FAILED (payments/other
# actions still succeed - notifications never block the primary action).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_NAME="School ERP"
# Optional - the "From" display address shown to recipients, if it
# should be different from SMTP_USER above (e.g. a shared relay
# account that authenticates as one address but sends "from" a
# different, nicer-looking one). SMTP_USER is ALWAYS still used for
# the actual SMTP authentication - this only changes what appears in
# the email's "From" header. Leave blank to keep using SMTP_USER for
# both (previous/default behavior).
SMTP_FROM_EMAIL=""

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# Cloud storage (Phase 6) - optional. Leave STORAGE_PROVIDER unset (or
# "local") to keep saving uploads to local disk (UPLOAD_DIR above).
# Set to "s3" to use real AWS S3 or a generic S3-compatible service
# (MinIO, DigitalOcean Spaces, Backblaze B2 - set S3_ENDPOINT for any
# of those; leave it blank for real AWS S3). For Cloudflare R2
# specifically, prefer STORAGE_PROVIDER="r2" and the R2_* variables
# below instead (see the Cloudflare R2 section further down) - keeps
# R2 credentials separate from a possibly-different S3 provider's.
STORAGE_PROVIDER="local"
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
# Optional CDN/CloudFront domain to serve files from instead of the
# raw bucket URL, e.g. "https://cdn.myschool.com".
S3_PUBLIC_URL=""

# Cloudflare R2 (S3-compatible object storage) - set STORAGE_PROVIDER
# above to "r2" to enable. All uploaded files (student/staff documents,
# avatars, exam question papers, DOCX templates, generated
# certificates) are stored here instead of local disk when active -
# see backend/src/config/r2.ts.
#
# Where to get each value (Cloudflare Dashboard -> R2):
#   R2_ACCOUNT_ID        - shown on the R2 Overview page / account sidebar
#   R2_ACCESS_KEY_ID      - R2 -> Manage R2 API Tokens -> Create API Token
#   R2_SECRET_ACCESS_KEY  - shown ONCE when the API Token is created - save it immediately
#   R2_BUCKET_NAME        - the bucket name you created in R2 -> Create bucket
#   R2_ENDPOINT           - optional; always https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
#                           - derived automatically from R2_ACCOUNT_ID if left blank
#   R2_PUBLIC_URL         - bucket -> Settings -> Public Access: either the
#                           "R2.dev subdomain" URL (quick/testing) or a
#                           connected custom domain (recommended for production)
#   R2_REGION             - optional; R2 ignores this value, defaults to "auto"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_ENDPOINT=""
R2_PUBLIC_URL=""
R2_REGION="auto"

# API documentation (Phase 6) - Swagger UI at GET /api/docs. Defaults
# to enabled outside production, disabled in production (an API
# surface map is itself information a public deployment may not want
# to expose). Set explicitly to "true"/"false" to override the default
# for your environment.
DOCS_ENABLED=""

# Monitoring & Logging (Phase 1) - both are optional; the app runs fine
# with neither set, it just falls back to console-only logging and no
# error tracking.
# Winston log level (error|warn|info|http|verbose|debug|silly). Defaults
# to "debug" in development, "info" everywhere else if unset.
LOG_LEVEL=""
# Sentry DSN (Project Settings > Client Keys (DSN) in your Sentry
# project). Leave blank to disable error tracking entirely.
SENTRY_DSN=""
# Fraction (0-1) of transactions to trace for performance monitoring.
# 0.1 = 10% - keep low in production to control Sentry usage/cost.
SENTRY_TRACES_SAMPLE_RATE="0.1"

# Redis (Phase 4 caching + Phase 5 background job queues) - optional.
# Leave blank to disable both entirely: caching falls back to hitting
# the database directly on every read, and background jobs (e.g. fee
# reminders) run synchronously inline instead of on a separate worker
# process. Matches docker-compose.yml's Redis service for local dev.
REDIS_URL="redis://localhost:6379"
