# Database (Neon for trial, Postgres for production)
DATABASE_URL="postgresql://user:password@host:5432/school_erp?schema=public"

# Backend
PORT=5000
NODE_ENV=development
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# Frontend URL - used by the backend to build OAuth redirect links and for
# CORS (must match the origin the Next.js app is actually served from).
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
NEXT_PUBLIC_APP_NAME="School ERP"

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
# Set this to the "Secret" shown when you add a webhook endpoint in the
# Razorpay Dashboard (Settings > Webhooks), pointing at
# POST {your-backend-url}/api/fees/razorpay/webhook. Required for the
# webhook handler to verify events actually came from Razorpay - without
# it, the webhook endpoint refuses to process events (fails closed).
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# SMS Gateway (MSG91 by default - see backend/src/services/notification/smsProvider.ts)
SMS_PROVIDER="msg91"
SMS_API_KEY="your-msg91-authkey"
SMS_SENDER_ID="SCHLRP"
# Optional: DLT-registered MSG91 Flow template ID. If unset, falls back
# to a plain-text send (only reliable for MSG91 trial/international
# numbers - Indian production sends require a DLT template).
SMS_TEMPLATE_ID=""
SMS_ROUTE="4"

# WhatsApp Business API (Interakt by default - see whatsappProvider.ts)
WHATSAPP_API_KEY="your-whatsapp-api-key"
WHATSAPP_API_URL="https://api.interakt.ai/v1/public"

# Push Notifications (Firebase Cloud Messaging, HTTP v1 API) - values
# come from the Firebase service-account JSON (Project Settings >
# Service Accounts > Generate new private key).
FCM_PROJECT_ID="your-firebase-project-id"
FCM_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# Paste the private_key field from the service account JSON, with real
# newlines replaced by "\n" (this is unescaped automatically at load
# time - see backend/src/config/index.ts).
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIExampleKeyContentHere\n-----END PRIVATE KEY-----\n"

# Email (SMTP/SendGrid) - used for real email notifications (fee
# payment confirmations, etc). If unset, email sending is skipped and
# the corresponding Notification row is marked FAILED (payments/other
# actions still succeed - notifications never block the primary action).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_NAME="School ERP"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# Monitoring & Logging (Phase 1) - both are optional; the app runs fine
# with neither set, it just falls back to console-only logging and no
# error tracking.
# Winston log level (error|warn|info|http|verbose|debug|silly). Defaults
# to "debug" in development, "info" everywhere else if unset.
LOG_LEVEL=""
# Sentry DSN (Project Settings > Client Keys (DSN) in your Sentry
# project). Leave blank to disable error tracking entirely.
SENTRY_DSN=""
# Fraction (0-1) of transactions to trace for performance monitoring.
# 0.1 = 10% - keep low in production to control Sentry usage/cost.
SENTRY_TRACES_SAMPLE_RATE="0.1"

# Redis (Phase 4 caching + Phase 5 background job queues) - optional.
# Leave blank to disable both entirely: caching falls back to hitting
# the database directly on every read, and background jobs (e.g. fee
# reminders) run synchronously inline instead of on a separate worker
# process. Matches docker-compose.yml's Redis service for local dev.
REDIS_URL="redis://localhost:6379"
