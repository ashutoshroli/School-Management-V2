{
  "name": "school-erp",
  "version": "1.0.0",
  "private": true,
  "description": "School ERP - Full Management System (Multi-branch, 15k+ students)",
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "db:generate": "npm run generate --prefix db",
    "db:migrate": "npm run migrate --prefix db",
    "db:seed": "npm run seed --prefix db",
    "db:studio": "npm run studio --prefix db",
    "db:backup": "./scripts/backup-database.sh",
    "db:restore": "./scripts/restore-database.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
