// School ERP - Full Database Schema
// Multi-branch, Multi-tenant Architecture
// All tables scoped by branchId (except Organization & SuperAdmin)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// SECTION 1: ORGANIZATION & BRANCH (Multi-tenant)
// ============================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  email     String?
  phone     String?
  website   String?
  address   String?
  city      String?
  state     String?
  pincode   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches Branch[]
  users    User[]
}

model Branch {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String   @unique
  address        String?
  city           String?
  state          String?
  pincode        String?
  phone          String?
  email          String?
  logo           String?
  isActive       Boolean  @default(true)
  // --- Branch Independence Principle: per-branch configurable rules ---
  // Roll number assignment rule (spec Section 18) - branch-wide policy
  // for how rollNo is decided once a student's Class & Section are
  // assigned (alphabetical is always the tiebreaker/fallback in either
  // mode, applied in the roll-number assignment service).
  rollNumberRule           RollNumberRule @default(ALPHABETICAL)
  // Timetable clash-detection mode for ROOM double-booking (spec
  // Section 20) - branch-configurable warning-only vs hard block.
  roomClashMode            ClashMode      @default(WARNING)
  // Timetable clash-detection mode for TEACHER double-booking (spec
  // Section 20) - same branch-configurable warning-vs-block choice as
  // roomClashMode above. Defaults to BLOCK (not WARNING) because a
  // teacher clash was ALWAYS a hard block before this field existed
  // (timetable.controller.ts's upsertSlot never had a
  // warning-only path for it) - this default preserves that exact
  // pre-existing behavior for every branch that never touches this
  // new setting, while still letting a branch opt into warning-only
  // if they want the same flexibility they already have for rooms.
  teacherClashMode         ClashMode      @default(BLOCK)
  // No fixed gap rule between exams (spec Section 20) - branch-custom
  // minimum number of days required between two exams for the same
  // class. 0 = no gap enforced (default, fully backward compatible).
  examMinGapDays           Int            @default(0)
  // School's own custom "week cycle" length in days (spec Section 6) -
  // used for the teacher late/early-penalty rolling window instead of
  // a fixed Mon-Sun week. Defaults to 7 (a normal week) so existing
  // branches behave exactly as before until explicitly changed.
  attendanceWeekCycleDays  Int            @default(7)
  // Every 5 combined late-entries+early-exits in one week-cycle
  // deducts this many periods from that day's attendance (spec
  // Section 6) - branch-configurable, defaults to the spec's stated
  // rule (5 occurrences -> 1 period deducted).
  lateEarlyPenaltyThreshold Int           @default(5)
  lateEarlyPenaltyPeriods   Int           @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  academicYears   AcademicYear[]
  classes         Class[]
  sections        Section[]
  subjects        Subject[]
  students        Student[]
  staff           Staff[]
  feeCategories   FeeCategory[]
  feeStructures   FeeStructure[]
  payments        Payment[]
  accounts        Account[]
  vouchers        Voucher[]
  notices         Notice[]
  routes          TransportRoute[]
  vehicles        Vehicle[]
  hostelBuildings HostelBuilding[]
  schoolBuildings SchoolBuilding[]
  periodConfigs   PeriodConfig[]
  holidays        Holiday[]
  libraryBooks    LibraryBook[]
  inventoryItems  InventoryItem[]
  devices         AttendanceDevice[]
  admissionInquiries AdmissionInquiry[]
  jobVacancies    JobVacancy[]
  // --- New modules (see each model's own doc comment for details) ---
  studentTransfersOut StudentBranchTransfer[] @relation("StudentTransferOriginBranch")
  studentTransfersIn  StudentBranchTransfer[] @relation("StudentTransferDestinationBranch")
  staffTransfersOut   StaffBranchTransfer[]   @relation("StaffTransferOriginBranch")
  staffTransfersIn    StaffBranchTransfer[]   @relation("StaffTransferDestinationBranch")
  roomBookings        RoomBooking[]
  messMenus           MessMenu[]
  messBills           MessBill[]
  canteenItems        CanteenItem[]
  canteenWallets      CanteenWallet[]
  labEquipment        LabEquipment[]
  dieselRequests      DieselRequest[]
  appraisalRatings    AppraisalRating[]
  admissionEntranceTests EntranceTestResult[]
  galleryImages       GalleryImage[]
  publicFeedback      PublicFeedback[]
}

// Roll number assignment policy (spec Section 18) - branch-configurable.
// Alphabetical order is always used as the fallback/tiebreaker in
// either mode (implemented in the roll-number assignment service, run
// on a student's first attendance day).
enum RollNumberRule {
  PERFORMANCE_BASED
  FEES_BASED
  ALPHABETICAL
}

// Timetable clash-detection mode (spec Section 20) - branch-configurable
// warning-vs-block, used by both Branch.roomClashMode (room
// double-booking) and Branch.teacherClashMode (teacher double-booking).
enum ClashMode {
  WARNING
  BLOCK
}


// ============================================
// SECTION 2: ACADEMIC YEAR & SESSION
// ============================================

model AcademicYear {
  id        String   @id @default(cuid())
  branchId  String
  name      String   // e.g., "2025-26"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch        Branch         @relation(fields: [branchId], references: [id])
  feeStructures FeeStructure[]
  exams         Exam[]
  timetables    Timetable[]
  promotions    Promotion[]

  @@unique([branchId, name])
}

// ============================================
// SECTION 3: USERS, ROLES & PERMISSIONS
// ============================================

enum UserRole {
  SUPER_ADMIN
  BRANCH_ADMIN
  PRINCIPAL
  // Vice Principal - scoped to their own branch like PRINCIPAL, sits
  // one level below Principal in the leave-approval chain (Staff -> VP
  // -> Principal, see leave.controller.ts) and participates in the
  // VP<->Teacher mutual quarterly appraisal rating (see
  // AppraisalRating below).
  VICE_PRINCIPAL
  TEACHER
  ACCOUNTANT
  LIBRARIAN
  TRANSPORT_MANAGER
  WARDEN
  STAFF
  STUDENT
  PARENT
}

model User {
  id             String       @id @default(cuid())
  organizationId String?
  email          String       @unique
  password       String?      // null for Google OAuth only users
  name           String
  phone          String?
  avatar         String?
  role           UserRole
  isActive       Boolean      @default(true)
  googleId       String?      @unique
  lastLogin      DateTime?
  // "Remember Me" login option - when true, refresh tokens issued for
  // this login should use the longer-lived TTL (see auth.controller.ts's
  // login()) instead of the normal session-length TTL. Purely a
  // per-login preference read at login time, not a permanent account
  // setting - stored here only so a fresh login can default to the
  // user's last choice.
  rememberMePreferred Boolean @default(false)
  // Super Admin "global bypass flag" (spec section 3) - an explicit,
  // configurable toggle layered ON TOP of the SUPER_ADMIN role check
  // already enforced everywhere via canAccessBranch/authorize. Every
  // SUPER_ADMIN defaults to bypassAllChecks: true at creation (see
  // auth.controller.ts / branch admin creation flow) so existing
  // behavior is unchanged, but a Super Admin account can have this
  // explicitly turned off (e.g. a restricted/audit-only Super Admin
  // login) without changing its role.
  bypassAllChecks Boolean @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization?   @relation(fields: [organizationId], references: [id])
  staff          Staff?
  student        Student?
  parent         Parent?
  permissions    UserPermission[]
  deviceTokens   DeviceToken[]
  loginSessions  LoginSession[]  // Session tracking for token refresh
}


model Permission {
  id          String   @id @default(cuid())
  module      String   // e.g., "fees", "attendance", "payroll"
  action      String   // e.g., "create", "read", "update", "delete"
  description String?
  createdAt   DateTime @default(now())

  userPermissions UserPermission[]

  @@unique([module, action])
}

model UserPermission {
  id           String @id @default(cuid())
  userId       String
  permissionId String

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
}

// ============================================
// SECTION 4: STAFF (HR)
// ============================================

model Staff {
  id            String    @id @default(cuid())
  userId        String    @unique
  branchId      String
  employeeId    String    @unique
  designation   String
  department    String
  type          StaffType
  qualification String?
  experience    String?
  joiningDate   DateTime
  leavingDate   DateTime?
  bankAccount   String?
  bankName      String?
  ifscCode      String?
  panNumber     String?
  aadharNumber  String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  cardId        String?   @unique // RFID Card ID
  isActive      Boolean   @default(true)
  // Only meaningful when the assigned "Staff Type"/System Role is
  // "Others" (see frontend Staff form) - free text label the admin
  // typed in for a role that isn't one of the fixed UserRole options.
  // Nullable/unused for every normal role.
  customStaffType String?
  // Timetable rule (see timetable.controller.ts's upsertSlot): the
  // maximum number of periods this teacher may be assigned across a
  // single day, checked at slot-assignment time so a teacher never
  // gets overloaded. 0/null = no limit configured yet (fully backward
  // compatible with every teacher created before this field existed).
  maxPeriodsPerDay Int?     @default(0)
  // Director-set custom working-days count for THIS specific staff
  // member (spec Section 7) - overrides the auto-calculated
  // per-role/per-branch/per-year working-days figure used for leave
  // quota + payroll attendance % purposes. null = use the
  // auto-calculated value (default, backward compatible).
  customWorkingDaysPerYear Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  branch          Branch            @relation(fields: [branchId], references: [id])
  salaryStructure SalaryStructure?
  attendances     StaffAttendance[]
  leaves          LeaveApplication[]
  payslips        Payslip[]
  documents       StaffDocument[]
  // One-to-one now (see Section.classTeacherId's @unique) - a staff
  // member can be the class teacher of AT MOST one section at a time.
  classTeacher    Section?          @relation("ClassTeacher")
  subjectTeachers SubjectTeacher[]
  timetableSlots  TimetableSlot[]
  assignedRooms   SchoolRoom[]      @relation("RoomAssignedStaff")
  assignedCabins  RoomCabin[]       @relation("CabinAssignedStaff")
  transfersOut        StaffBranchTransfer[]   @relation("StaffTransferSubject")
  roomBookingsRequested RoomBooking[]         @relation("RoomBookingRequestedBy")
  labIssuesReceived    LabEquipmentIssue[]     @relation("LabIssueStaffReceiver")
  dieselRequestsRaised DieselRequest[]         @relation("DieselRequestDriver")
  ratingsAsSubject     AppraisalRating[]       @relation("AppraisalRatingSubject")
  ratingsAsRater       AppraisalRating[]       @relation("AppraisalRatingRater")
  invigilatorDuties    ExamInvigilator[]
  substituteAssignmentsGiven LeaveSubstituteAssignment[] @relation("SubstituteStaff")
}


enum StaffType {
  TEACHING
  NON_TEACHING
}

model StaffDocument {
  id         String   @id @default(cuid())
  staffId    String
  name       String
  type       String   // resume, certificate, aadhar, pan, photo
  fileUrl    String
  // File metadata (Cloudflare R2 migration) - the actual file bytes
  // live in R2, never in this table; these three columns are the only
  // extra bookkeeping needed alongside fileUrl. Nullable since rows
  // created before this migration won't have them backfilled.
  fileSize   Int?     // bytes
  mimeType   String?
  uploadedBy String?  // userId of whoever uploaded this document
  createdAt  DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id])
}

// ============================================
// SECTION 5: STUDENTS & PARENTS
// ============================================

model Student {
  id              String   @id @default(cuid())
  userId          String   @unique
  branchId        String
  admissionNo     String   @unique
  rollNo          String?
  classId         String
  sectionId       String
  dateOfBirth     DateTime
  gender          Gender
  bloodGroup      String?
  religion        String?
  caste           String?
  category        String?  // General, OBC, SC, ST
  nationality     String?  @default("Indian")
  motherTongue    String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  previousSchool  String?
  admissionDate   DateTime @default(now())
  leavingDate     DateTime?
  leavingReason   String?
  cardId          String?  @unique // RFID Card ID
  isActive        Boolean  @default(true)
  // Roll number has been assigned yet? (spec Section 18: "Roll Number
  // assigned on the STUDENT'S FIRST ATTENDANCE DAY, not at admission")
  // - rollNo itself stays nullable/free-editable as before; this flag
  // just tracks whether the automatic first-attendance-day assignment
  // has already run for this student, so it only ever fires once.
  rollNoAssignedAt DateTime?
  // Scholarship auto-cancellation on branch transfer (spec Section 5) -
  // when true, this student currently holds an active scholarship
  // that must be auto-cancelled (see completeStudentTransfer in
  // branchTransfer.controller.ts) the moment a branch transfer
  // completes; reset to false once cancelled. Kept as a simple flag
  // rather than a new full scholarship model, since scholarships are
  // otherwise represented generically via StudentDiscount
  // (MERIT_SCHOLARSHIP type) - this flag exists purely so a transfer
  // knows whether it needs to deactivate one.
  hasActiveScholarship Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  branch          Branch            @relation(fields: [branchId], references: [id])
  class           Class             @relation(fields: [classId], references: [id])
  section         Section           @relation(fields: [sectionId], references: [id])
  parents         StudentParent[]
  documents       StudentDocument[]
  feeAssignments  FeeAssignment[]
  payments        Payment[]
  attendances     StudentAttendance[]
  marks           Mark[]
  homeworkSubmissions HomeworkSubmission[]
  homeworkRecheckRequests HomeworkRecheckRequest[]
  libraryIssues   LibraryIssue[]
  transportAllocation TransportAllocation?
  hostelAllocation    HostelAllocation?
  hostelRoomRequests  HostelRoomRequest[] @relation("HostelRoomRequestStudent")
  roommateApprovalsGiven HostelRoomRequest[] @relation("HostelRoomRequestRoommate")
  promotions      Promotion[]
  discounts       StudentDiscount[]
  certificates    GeneratedCertificate[]
  examSeatAllocations ExamSeatAllocation[]
  examAttendances     ExamAttendance[]
  admitCards          AdmitCard[]
  branchTransfers     StudentBranchTransfer[]
  labIssuesReceived   LabEquipmentIssue[] @relation("LabIssueStudentReceiver")
  canteenWallet       CanteenWallet?
  appraisalRatingsGiven AppraisalRating[] @relation("AppraisalRatingStudentRater")
  entranceTestResult  EntranceTestResult?
}


enum Gender {
  MALE
  FEMALE
  OTHER
}

model StudentDocument {
  id         String   @id @default(cuid())
  studentId  String
  name       String
  type       String   // photo, birth_cert, aadhar, tc, marksheet
  fileUrl    String
  // File metadata (Cloudflare R2 migration) - see StaffDocument's
  // identical comment above.
  fileSize   Int?     // bytes
  mimeType   String?
  uploadedBy String?  // userId of whoever uploaded this document
  createdAt  DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model Parent {
  id        String   @id @default(cuid())
  userId    String   @unique
  relation  ParentRelation
  occupation String?
  income     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  children StudentParent[]
}

enum ParentRelation {
  FATHER
  MOTHER
  GUARDIAN
}

model StudentParent {
  id        String @id @default(cuid())
  studentId String
  parentId  String

  student Student @relation(fields: [studentId], references: [id])
  parent  Parent  @relation(fields: [parentId], references: [id])

  @@unique([studentId, parentId])
}

// ============================================
// SECTION 6: CLASS, SECTION, SUBJECT
// ============================================

model Class {
  id        String   @id @default(cuid())
  branchId  String
  name      String   // e.g., "Class 1", "Nursery", "LKG"
  numericOrder Int   // for sorting: 0=Nursery, 1=LKG, 2=UKG, 3=1st...
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch          Branch           @relation(fields: [branchId], references: [id])
  sections        Section[]
  students        Student[]
  subjects        ClassSubject[]
  feeStructures   FeeStructure[]
  exams           Exam[]
  timetables      Timetable[]
  subjectTeachers SubjectTeacher[]

  @@unique([branchId, name])
}


model Section {
  id             String   @id @default(cuid())
  branchId       String
  classId        String
  name           String   // A, B, C...
  capacity       Int      @default(40)
  // @unique: a staff member can be the class teacher of AT MOST ONE
  // section at a time (enforced here at the DB level, in addition to
  // the friendlier pre-check in updateSection/createSection). Multiple
  // sections with classTeacherId: null is fine - Postgres treats every
  // NULL as distinct for a unique index, so any number of
  // not-yet-assigned sections can coexist.
  classTeacherId String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch       Branch    @relation(fields: [branchId], references: [id])
  class        Class     @relation(fields: [classId], references: [id])
  classTeacher Staff?    @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  // Optional physical classroom this section meets in (see SECTION 26:
  // SCHOOL BUILDING/ROOMS below) - lets the room's "occupied seats"
  // figure be derived from this section's live student headcount
  // instead of needing separate manual seat-tracking.
  roomId       String?
  room         SchoolRoom? @relation(fields: [roomId], references: [id])
  // Additional rooms this section uses beyond its one primary
  // classroom above (e.g. a shared Lab, Library slot, or Auditorium
  // for special periods) - see SectionRoom below. The single `room`
  // FK stays exactly as-is for the common "one classroom" case; this
  // is purely additive/opt-in multi-room support for the "Class
  // Assign" module's bulk multi-select workflow.
  additionalRooms SectionRoom[]
  students     Student[]
  attendances  StudentAttendance[]
  timetable    Timetable?
  examQuestionPapers ExamQuestionPaper[]
  exams        Exam[]

  @@unique([classId, name])
}

// Many-to-many mapping letting a Section be linked to MULTIPLE
// SchoolRooms at once (beyond its single primary Section.roomId), and
// symmetrically letting one SchoolRoom be shared by multiple Sections
// (e.g. a shared Lab/Auditorium used by several classes) - the "Class
// Assign" module's bulk multi-select workflow creates/removes rows
// here in bulk rather than one manual pick at a time.
model SectionRoom {
  id        String   @id @default(cuid())
  sectionId String
  roomId    String
  createdAt DateTime @default(now())

  section Section    @relation(fields: [sectionId], references: [id])
  room    SchoolRoom @relation(fields: [roomId], references: [id])

  @@unique([sectionId, roomId])
}

model Subject {
  id        String      @id @default(cuid())
  branchId  String
  name      String
  code      String
  type      SubjectType @default(THEORY)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  branch          Branch           @relation(fields: [branchId], references: [id])
  classSubjects   ClassSubject[]
  subjectTeachers SubjectTeacher[]
  marks           Mark[]
  homeworks       Homework[]
  examSchedules   ExamSchedule[]

  @@unique([branchId, code])
}

enum SubjectType {
  THEORY
  PRACTICAL
  ELECTIVE
}

model ClassSubject {
  id        String @id @default(cuid())
  classId   String
  subjectId String

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([classId, subjectId])
}

model SubjectTeacher {
  id        String @id @default(cuid())
  staffId   String
  subjectId String
  classId   String?

  staff   Staff   @relation(fields: [staffId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  class   Class?  @relation(fields: [classId], references: [id])

  @@unique([staffId, subjectId, classId])
}


// ============================================
// SECTION 7: FEES MODULE
// ============================================

model FeeCategory {
  id        String   @id @default(cuid())
  branchId  String
  name      String   // Tuition, Transport, Hostel, Exam, Uniform, Custom...
  code      String
  isSystem  Boolean  @default(false) // system-defined or custom
  isActive  Boolean  @default(true)
  // Mandatory vs opt-in (spec Section 19 - "Director/Principal can
  // create custom fee categories and mark each as mandatory or
  // optional"). System categories (Tuition, Admission) are always
  // effectively mandatory regardless of this flag; it's primarily
  // meaningful for custom categories (Transport/Hostel are already
  // naturally opt-in via their own allocation-based assignment flow).
  isMandatory Boolean @default(true)
  // Late fee grace period in days (spec Section 19 - "3-day grace
  // period after due date before late fee starts applying"),
  // configurable PER FEE CATEGORY as the spec states. Defaults to 3
  // (the spec's stated default) so every existing category gets the
  // spec-correct behavior without needing manual configuration.
  lateFeeGraceDays Int @default(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch        Branch         @relation(fields: [branchId], references: [id])
  feeStructures FeeStructure[]

  @@unique([branchId, code])
}

model FeeStructure {
  id              String          @id @default(cuid())
  branchId        String
  academicYearId  String
  // Nullable: a fee structure is EITHER class-wise (classId set,
  // transportRouteId null) OR transport-route-wise (transportRouteId
  // set, classId null) - never both, never neither. Enforced in
  // application code (feeStructure.controller.ts's createFeeStructure
  // and the new transport fee assignment controller), not at the DB
  // level, since Prisma has no portable CHECK-constraint support.
  classId         String?
  transportRouteId String?
  feeCategoryId   String
  amount          Decimal         @db.Decimal(12, 2)
  frequency       FeeFrequency
  dueDay          Int             @default(10) // day of month
  lateFeeType     LateFeeType     @default(FIXED)
  lateFeeValue    Decimal         @default(0) @db.Decimal(10, 2)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  branch         Branch         @relation(fields: [branchId], references: [id])
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])
  class          Class?         @relation(fields: [classId], references: [id])
  transportRoute TransportRoute? @relation(fields: [transportRouteId], references: [id])
  feeCategory    FeeCategory    @relation(fields: [feeCategoryId], references: [id])
  feeAssignments FeeAssignment[]
  installments   FeeInstallment[]

  // NOTE: Postgres treats NULL as distinct from every other value in a
  // unique index, so each of these two constraints is only actually
  // enforced for the row "shape" where its own key columns are
  // non-null - class-wise structures (transportRouteId always null)
  // are deduped by the first constraint; transport-route-wise
  // structures (classId always null) are deduped by the second. They
  // don't interfere with each other.
  @@unique([branchId, academicYearId, classId, feeCategoryId])
  @@unique([branchId, academicYearId, transportRouteId, feeCategoryId])
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  ONE_TIME
}

enum LateFeeType {
  FIXED       // fixed amount per day/month
  PERCENTAGE  // % of pending amount
  NONE
}


model FeeInstallment {
  id             String   @id @default(cuid())
  feeStructureId String
  installmentNo  Int
  amount         Decimal  @db.Decimal(12, 2)
  dueDate        DateTime
  createdAt      DateTime @default(now())

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])

  @@unique([feeStructureId, installmentNo])
}

model FeeAssignment {
  id             String   @id @default(cuid())
  studentId      String
  feeStructureId String
  totalAmount    Decimal  @db.Decimal(12, 2)
  paidAmount     Decimal  @default(0) @db.Decimal(12, 2)
  discount       Decimal  @default(0) @db.Decimal(12, 2)
  lateFee        Decimal  @default(0) @db.Decimal(12, 2)
  status         FeeStatus @default(PENDING)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student      Student      @relation(fields: [studentId], references: [id])
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  payments     Payment[]
  discounts    StudentDiscount[]

  @@unique([studentId, feeStructureId])
  // Phase 5 (Performance): the defaulters list/CSV/fee-reminder flows
  // (fetchDefaulters in feeReports.controller.ts, sendFeeReminders in
  // feeReminder.service.ts) all filter FeeAssignment by status - this
  // is the single most repeated WHERE clause against this table.
  @@index([status])
}

enum FeeStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

// BUG FIX: previously had NO link to any FeeAssignment at all -
// assigning a discount only ever created a row here; nothing ever
// copied its value into FeeAssignment.discount (the column
// getStudentPendingFees/recordFeePayment actually read to compute the
// pending/due amount), so a granted discount never reduced anything a
// student owed. feeAssignmentId now ties a discount to the ONE
// specific fee it applies to (e.g. "10% off this year's Tuition Fee"),
// and every create/toggle/delete of a StudentDiscount recalculates its
// linked FeeAssignment.discount from the sum of its currently-active
// linked discounts (see feePayment.service.ts's
// recalculateFeeAssignmentDiscount).
//
// Nullable (not required) so pre-existing rows created before this
// migration - which were never linked to any fee and had no effect -
// don't break; they simply continue to have no effect (unchanged
// behavior for them), rather than crashing the migration or being
// guessed at automatically (which fee a legacy discount was intended
// for is genuinely ambiguous when a student has more than one).
model StudentDiscount {
  id             String       @id @default(cuid())
  studentId      String
  feeAssignmentId String?
  type           DiscountType
  name           String       // "Sibling Discount", "Merit Scholarship", "RTE", "Staff Ward"
  value          Decimal      @db.Decimal(10, 2)
  isPercent      Boolean      @default(false)
  isActive       Boolean      @default(true)
  // Sibling discount is NOT automatic - requires manual Principal
  // approval (spec Section 19). Only meaningful when type is SIBLING;
  // isActive is now gated on this being APPROVED for that type (see
  // recalculateFeeAssignmentDiscount / discount.controller.ts) so an
  // unapproved sibling-discount request never silently reduces a fee.
  // Every other discount type defaults to APPROVED (unchanged prior
  // behavior - approval is a new rule specific to SIBLING).
  approvalStatus DiscountApprovalStatus @default(APPROVED)
  approvedBy     String?
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  student       Student        @relation(fields: [studentId], references: [id])
  feeAssignment FeeAssignment? @relation(fields: [feeAssignmentId], references: [id])
}

enum DiscountApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  SIBLING
  MERIT_SCHOLARSHIP
  RTE
  STAFF_WARD
  CUSTOM
}


model Payment {
  id              String        @id @default(cuid())
  branchId        String
  studentId       String
  feeAssignmentId String
  amount          Decimal       @db.Decimal(12, 2)
  lateFeeCharged  Decimal       @default(0) @db.Decimal(10, 2)
  paymentMode     PaymentMode
  transactionId   String?       // online payment gateway ref
  chequeNo        String?
  chequeDate      DateTime?
  bankName        String?
  receiptNo       String        @unique
  receiptUrl      String?       // generated PDF URL
  remarks         String?
  status          PaymentStatus @default(SUCCESS)
  paidAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  branch        Branch        @relation(fields: [branchId], references: [id])
  student       Student       @relation(fields: [studentId], references: [id])
  feeAssignment FeeAssignment @relation(fields: [feeAssignmentId], references: [id])
  voucherEntry  Voucher?      // auto-posted to accounting
  refund        Refund?

  // Phase 5 (Performance): paidAt/status are the two columns nearly
  // every fee-reports query (day book, collection trend, payment mode
  // breakdown - see feeReports.controller.ts) filters on, always
  // scoped to a branch. studentId speeds up "this student's payment
  // history" lookups (getStudentPayments).
  @@index([branchId, paidAt])
  @@index([branchId, status])
  @@index([studentId])
}

enum PaymentMode {
  CASH
  CHEQUE
  DD
  ONLINE_RAZORPAY
  ONLINE_PAYU
  UPI
  BANK_TRANSFER
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
  REFUNDED
}

model Refund {
  id        String   @id @default(cuid())
  paymentId String   @unique
  amount    Decimal  @db.Decimal(12, 2)
  reason    String
  approvedBy String?
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
}


// ============================================
// SECTION 8: ACCOUNTING (Double-Entry Ledger)
// ============================================

model Account {
  id          String      @id @default(cuid())
  branchId    String
  name        String
  code        String
  type        AccountType
  parentId    String?     // tree structure
  isSystem    Boolean     @default(false)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id])
  parent         Account?        @relation("AccountTree", fields: [parentId], references: [id])
  children       Account[]       @relation("AccountTree")
  debitEntries   VoucherEntry[]  @relation("DebitAccount")
  creditEntries  VoucherEntry[]  @relation("CreditAccount")

  @@unique([branchId, code])
}

enum AccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  CAPITAL
}

model Voucher {
  id          String      @id @default(cuid())
  branchId    String
  voucherNo   String
  type        VoucherType
  date        DateTime
  narration   String?
  paymentId   String?     @unique // linked to fee payment (auto-post)
  totalAmount Decimal     @db.Decimal(12, 2)
  isApproved  Boolean     @default(false)
  approvedBy  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  branch  Branch         @relation(fields: [branchId], references: [id])
  payment Payment?       @relation(fields: [paymentId], references: [id])
  entries VoucherEntry[]

  @@unique([branchId, voucherNo])
