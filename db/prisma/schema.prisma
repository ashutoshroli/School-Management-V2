// School ERP - Full Database Schema
// Multi-branch, Multi-tenant Architecture
// All tables scoped by branchId (except Organization & SuperAdmin)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// SECTION 1: ORGANIZATION & BRANCH (Multi-tenant)
// ============================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  email     String?
  phone     String?
  website   String?
  address   String?
  city      String?
  state     String?
  pincode   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches Branch[]
  users    User[]
}

model Branch {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String   @unique
  address        String?
  city           String?
  state          String?
  pincode        String?
  phone          String?
  email          String?
  logo           String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  academicYears   AcademicYear[]
  classes         Class[]
  sections        Section[]
  subjects        Subject[]
  students        Student[]
  staff           Staff[]
  feeCategories   FeeCategory[]
  feeStructures   FeeStructure[]
  payments        Payment[]
  accounts        Account[]
  vouchers        Voucher[]
  notices         Notice[]
  routes          TransportRoute[]
  vehicles        Vehicle[]
  hostelBuildings HostelBuilding[]
  schoolBuildings SchoolBuilding[]
  periodConfigs   PeriodConfig[]
  holidays        Holiday[]
  libraryBooks    LibraryBook[]
  inventoryItems  InventoryItem[]
  devices         AttendanceDevice[]
  admissionInquiries AdmissionInquiry[]
  jobVacancies    JobVacancy[]
}


// ============================================
// SECTION 2: ACADEMIC YEAR & SESSION
// ============================================

model AcademicYear {
  id        String   @id @default(cuid())
  branchId  String
  name      String   // e.g., "2025-26"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch        Branch         @relation(fields: [branchId], references: [id])
  feeStructures FeeStructure[]
  exams         Exam[]
  timetables    Timetable[]
  promotions    Promotion[]

  @@unique([branchId, name])
}

// ============================================
// SECTION 3: USERS, ROLES & PERMISSIONS
// ============================================

enum UserRole {
  SUPER_ADMIN
  BRANCH_ADMIN
  TEACHER
  ACCOUNTANT
  LIBRARIAN
  TRANSPORT_MANAGER
  WARDEN
  STAFF
  STUDENT
  PARENT
}

model User {
  id             String       @id @default(cuid())
  organizationId String?
  email          String       @unique
  password       String?      // null for Google OAuth only users
  name           String
  phone          String?
  avatar         String?
  role           UserRole
  isActive       Boolean      @default(true)
  googleId       String?      @unique
  lastLogin      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  staff        Staff?
  student      Student?
  parent       Parent?
  permissions  UserPermission[]
  deviceTokens DeviceToken[]
}


model Permission {
  id          String   @id @default(cuid())
  module      String   // e.g., "fees", "attendance", "payroll"
  action      String   // e.g., "create", "read", "update", "delete"
  description String?
  createdAt   DateTime @default(now())

  userPermissions UserPermission[]

  @@unique([module, action])
}

model UserPermission {
  id           String @id @default(cuid())
  userId       String
  permissionId String

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
}

// ============================================
// SECTION 4: STAFF (HR)
// ============================================

model Staff {
  id            String    @id @default(cuid())
  userId        String    @unique
  branchId      String
  employeeId    String    @unique
  designation   String
  department    String
  type          StaffType
  qualification String?
  experience    String?
  joiningDate   DateTime
  leavingDate   DateTime?
  bankAccount   String?
  bankName      String?
  ifscCode      String?
  panNumber     String?
  aadharNumber  String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  cardId        String?   @unique // RFID Card ID
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  branch          Branch            @relation(fields: [branchId], references: [id])
  salaryStructure SalaryStructure?
  attendances     StaffAttendance[]
  leaves          LeaveApplication[]
  payslips        Payslip[]
  documents       StaffDocument[]
  classTeacher    Section[]         @relation("ClassTeacher")
  subjectTeachers SubjectTeacher[]
  timetableSlots  TimetableSlot[]
  assignedRooms   SchoolRoom[]      @relation("RoomAssignedStaff")
  assignedCabins  RoomCabin[]       @relation("CabinAssignedStaff")
}


enum StaffType {
  TEACHING
  NON_TEACHING
}

model StaffDocument {
  id        String   @id @default(cuid())
  staffId   String
  name      String
  type      String   // resume, certificate, aadhar, pan, photo
  fileUrl   String
  createdAt DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id])
}

// ============================================
// SECTION 5: STUDENTS & PARENTS
// ============================================

model Student {
  id              String   @id @default(cuid())
  userId          String   @unique
  branchId        String
  admissionNo     String   @unique
  rollNo          String?
  classId         String
  sectionId       String
  dateOfBirth     DateTime
  gender          Gender
  bloodGroup      String?
  religion        String?
  caste           String?
  category        String?  // General, OBC, SC, ST
  nationality     String?  @default("Indian")
  motherTongue    String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  previousSchool  String?
  admissionDate   DateTime @default(now())
  leavingDate     DateTime?
  leavingReason   String?
  cardId          String?  @unique // RFID Card ID
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  branch          Branch            @relation(fields: [branchId], references: [id])
  class           Class             @relation(fields: [classId], references: [id])
  section         Section           @relation(fields: [sectionId], references: [id])
  parents         StudentParent[]
  documents       StudentDocument[]
  feeAssignments  FeeAssignment[]
  payments        Payment[]
  attendances     StudentAttendance[]
  marks           Mark[]
  homeworkSubmissions HomeworkSubmission[]
  libraryIssues   LibraryIssue[]
  transportAllocation TransportAllocation?
  hostelAllocation    HostelAllocation?
  promotions      Promotion[]
  discounts       StudentDiscount[]
  certificates    GeneratedCertificate[]
  examSeatAllocations ExamSeatAllocation[]
  examAttendances     ExamAttendance[]
  healthRecord        StudentHealth?
  disciplineIncidents DisciplineIncident[]
  quizAttempts        QuizAttempt[]
}


enum Gender {
  MALE
  FEMALE
  OTHER
}

model StudentDocument {
  id        String   @id @default(cuid())
  studentId String
  name      String
  type      String   // photo, birth_cert, aadhar, tc, marksheet
  fileUrl   String
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model Parent {
  id        String   @id @default(cuid())
  userId    String   @unique
  relation  ParentRelation
  occupation String?
  income     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  children StudentParent[]
}

enum ParentRelation {
  FATHER
  MOTHER
  GUARDIAN
}

model StudentParent {
  id        String @id @default(cuid())
  studentId String
  parentId  String

  student Student @relation(fields: [studentId], references: [id])
  parent  Parent  @relation(fields: [parentId], references: [id])

  @@unique([studentId, parentId])
}

// ============================================
// SECTION 6: CLASS, SECTION, SUBJECT
// ============================================

model Class {
  id        String   @id @default(cuid())
  branchId  String
  name      String   // e.g., "Class 1", "Nursery", "LKG"
  numericOrder Int   // for sorting: 0=Nursery, 1=LKG, 2=UKG, 3=1st...
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch          Branch           @relation(fields: [branchId], references: [id])
  sections        Section[]
  students        Student[]
  subjects        ClassSubject[]
  feeStructures   FeeStructure[]
  exams           Exam[]
  timetables      Timetable[]
  subjectTeachers SubjectTeacher[]

  @@unique([branchId, name])
}


model Section {
  id             String   @id @default(cuid())
  branchId       String
  classId        String
  name           String   // A, B, C...
  capacity       Int      @default(40)
  classTeacherId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch       Branch    @relation(fields: [branchId], references: [id])
  class        Class     @relation(fields: [classId], references: [id])
  classTeacher Staff?    @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  // Optional physical classroom this section meets in (see SECTION 26:
  // SCHOOL BUILDING/ROOMS below) - lets the room's "occupied seats"
  // figure be derived from this section's live student headcount
  // instead of needing separate manual seat-tracking.
  roomId       String?
  room         SchoolRoom? @relation(fields: [roomId], references: [id])
  students     Student[]
  attendances  StudentAttendance[]
  timetable    Timetable?
  examQuestionPapers ExamQuestionPaper[]

  @@unique([classId, name])
}

model Subject {
  id        String      @id @default(cuid())
  branchId  String
  name      String
  code      String
  type      SubjectType @default(THEORY)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  branch          Branch           @relation(fields: [branchId], references: [id])
  classSubjects   ClassSubject[]
  subjectTeachers SubjectTeacher[]
  marks           Mark[]
  homeworks       Homework[]
  examSchedules   ExamSchedule[]

  @@unique([branchId, code])
}

enum SubjectType {
  THEORY
  PRACTICAL
  ELECTIVE
}

model ClassSubject {
  id        String @id @default(cuid())
  classId   String
  subjectId String

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([classId, subjectId])
}

model SubjectTeacher {
  id        String @id @default(cuid())
  staffId   String
  subjectId String
  classId   String?

  staff   Staff   @relation(fields: [staffId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  class   Class?  @relation(fields: [classId], references: [id])

  @@unique([staffId, subjectId, classId])
}


// ============================================
// SECTION 7: FEES MODULE
// ============================================

model FeeCategory {
  id        String   @id @default(cuid())
  branchId  String
  name      String   // Tuition, Transport, Hostel, Exam, Uniform, Custom...
  code      String
  isSystem  Boolean  @default(false) // system-defined or custom
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch        Branch         @relation(fields: [branchId], references: [id])
  feeStructures FeeStructure[]

  @@unique([branchId, code])
}

model FeeStructure {
  id              String          @id @default(cuid())
  branchId        String
  academicYearId  String
  // Nullable: a fee structure is EITHER class-wise (classId set,
  // transportRouteId null) OR transport-route-wise (transportRouteId
  // set, classId null) - never both, never neither. Enforced in
  // application code (feeStructure.controller.ts's createFeeStructure
  // and the new transport fee assignment controller), not at the DB
  // level, since Prisma has no portable CHECK-constraint support.
  classId         String?
  transportRouteId String?
  feeCategoryId   String
  amount          Decimal         @db.Decimal(12, 2)
  frequency       FeeFrequency
  dueDay          Int             @default(10) // day of month
  lateFeeType     LateFeeType     @default(FIXED)
  lateFeeValue    Decimal         @default(0) @db.Decimal(10, 2)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  branch         Branch         @relation(fields: [branchId], references: [id])
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])
  class          Class?         @relation(fields: [classId], references: [id])
  transportRoute TransportRoute? @relation(fields: [transportRouteId], references: [id])
  feeCategory    FeeCategory    @relation(fields: [feeCategoryId], references: [id])
  feeAssignments FeeAssignment[]
  installments   FeeInstallment[]

  // NOTE: Postgres treats NULL as distinct from every other value in a
  // unique index, so each of these two constraints is only actually
  // enforced for the row "shape" where its own key columns are
  // non-null - class-wise structures (transportRouteId always null)
  // are deduped by the first constraint; transport-route-wise
  // structures (classId always null) are deduped by the second. They
  // don't interfere with each other.
  @@unique([branchId, academicYearId, classId, feeCategoryId])
  @@unique([branchId, academicYearId, transportRouteId, feeCategoryId])
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  ONE_TIME
}

enum LateFeeType {
  FIXED       // fixed amount per day/month
  PERCENTAGE  // % of pending amount
  NONE
}


model FeeInstallment {
  id             String   @id @default(cuid())
  feeStructureId String
  installmentNo  Int
  amount         Decimal  @db.Decimal(12, 2)
  dueDate        DateTime
  createdAt      DateTime @default(now())

  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])

  @@unique([feeStructureId, installmentNo])
}

model FeeAssignment {
  id             String   @id @default(cuid())
  studentId      String
  feeStructureId String
  totalAmount    Decimal  @db.Decimal(12, 2)
  paidAmount     Decimal  @default(0) @db.Decimal(12, 2)
  discount       Decimal  @default(0) @db.Decimal(12, 2)
  lateFee        Decimal  @default(0) @db.Decimal(12, 2)
  status         FeeStatus @default(PENDING)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student      Student      @relation(fields: [studentId], references: [id])
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id])
  payments     Payment[]

  @@unique([studentId, feeStructureId])
  // Phase 5 (Performance): the defaulters list/CSV/fee-reminder flows
  // (fetchDefaulters in feeReports.controller.ts, sendFeeReminders in
  // feeReminder.service.ts) all filter FeeAssignment by status - this
  // is the single most repeated WHERE clause against this table.
  @@index([status])
}

enum FeeStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

model StudentDiscount {
  id        String       @id @default(cuid())
  studentId String
  type      DiscountType
  name      String       // "Sibling Discount", "Merit Scholarship", "RTE", "Staff Ward"
  value     Decimal      @db.Decimal(10, 2)
  isPercent Boolean      @default(false)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  student Student @relation(fields: [studentId], references: [id])
}

enum DiscountType {
  SIBLING
  MERIT_SCHOLARSHIP
  RTE
  STAFF_WARD
  CUSTOM
}


model Payment {
  id              String        @id @default(cuid())
  branchId        String
  studentId       String
  feeAssignmentId String
  amount          Decimal       @db.Decimal(12, 2)
  lateFeeCharged  Decimal       @default(0) @db.Decimal(10, 2)
  paymentMode     PaymentMode
  transactionId   String?       // online payment gateway ref
  chequeNo        String?
  chequeDate      DateTime?
  bankName        String?
  receiptNo       String        @unique
  receiptUrl      String?       // generated PDF URL
  remarks         String?
  status          PaymentStatus @default(SUCCESS)
  paidAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  branch        Branch        @relation(fields: [branchId], references: [id])
  student       Student       @relation(fields: [studentId], references: [id])
  feeAssignment FeeAssignment @relation(fields: [feeAssignmentId], references: [id])
  voucherEntry  Voucher?      // auto-posted to accounting
  refund        Refund?

  // Phase 5 (Performance): paidAt/status are the two columns nearly
  // every fee-reports query (day book, collection trend, payment mode
  // breakdown - see feeReports.controller.ts) filters on, always
  // scoped to a branch. studentId speeds up "this student's payment
  // history" lookups (getStudentPayments).
  @@index([branchId, paidAt])
  @@index([branchId, status])
  @@index([studentId])
}

enum PaymentMode {
  CASH
  CHEQUE
  DD
  ONLINE_RAZORPAY
  ONLINE_PAYU
  UPI
  BANK_TRANSFER
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
  REFUNDED
}

model Refund {
  id        String   @id @default(cuid())
  paymentId String   @unique
  amount    Decimal  @db.Decimal(12, 2)
  reason    String
  approvedBy String?
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
}


// ============================================
// SECTION 8: ACCOUNTING (Double-Entry Ledger)
// ============================================

model Account {
  id          String      @id @default(cuid())
  branchId    String
  name        String
  code        String
  type        AccountType
  parentId    String?     // tree structure
  isSystem    Boolean     @default(false)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id])
  parent         Account?        @relation("AccountTree", fields: [parentId], references: [id])
  children       Account[]       @relation("AccountTree")
  debitEntries   VoucherEntry[]  @relation("DebitAccount")
  creditEntries  VoucherEntry[]  @relation("CreditAccount")

  @@unique([branchId, code])
}

enum AccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  CAPITAL
}

model Voucher {
  id          String      @id @default(cuid())
  branchId    String
  voucherNo   String
  type        VoucherType
  date        DateTime
  narration   String?
  paymentId   String?     @unique // linked to fee payment (auto-post)
  totalAmount Decimal     @db.Decimal(12, 2)
  isApproved  Boolean     @default(false)
  approvedBy  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  branch  Branch         @relation(fields: [branchId], references: [id])
  payment Payment?       @relation(fields: [paymentId], references: [id])
  entries VoucherEntry[]

  @@unique([branchId, voucherNo])
}

enum VoucherType {
  PAYMENT
  RECEIPT
  JOURNAL
  CONTRA
}

model VoucherEntry {
  id              String  @id @default(cuid())
  voucherId       String
  debitAccountId  String
  creditAccountId String
  amount          Decimal @db.Decimal(12, 2)
  narration       String?

  voucher       Voucher @relation(fields: [voucherId], references: [id])
  debitAccount  Account @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount Account @relation("CreditAccount", fields: [creditAccountId], references: [id])
}


// ============================================
// SECTION 9: PAYROLL & SALARY
// ============================================

model SalaryStructure {
  id             String  @id @default(cuid())
  staffId        String  @unique
  basic          Decimal @db.Decimal(10, 2)
  da             Decimal @default(0) @db.Decimal(10, 2) // Dearness Allowance
  hra            Decimal @default(0) @db.Decimal(10, 2)
  ta             Decimal @default(0) @db.Decimal(10, 2) // Travel Allowance
  specialAllow   Decimal @default(0) @db.Decimal(10, 2)
  medicalAllow   Decimal @default(0) @db.Decimal(10, 2)
  otherAllow     Decimal @default(0) @db.Decimal(10, 2)
  pfEmployee     Decimal @default(0) @db.Decimal(10, 2) // 12% of basic+DA
  pfEmployer     Decimal @default(0) @db.Decimal(10, 2) // 12% employer
  esiEmployee    Decimal @default(0) @db.Decimal(10, 2) // 0.75%
  esiEmployer    Decimal @default(0) @db.Decimal(10, 2) // 3.25%
  professionalTax Decimal @default(0) @db.Decimal(10, 2)
  tds            Decimal @default(0) @db.Decimal(10, 2) // monthly TDS
  otherDeduction Decimal @default(0) @db.Decimal(10, 2)
  grossSalary    Decimal @db.Decimal(10, 2)
  netSalary      Decimal @db.Decimal(10, 2)
  taxRegime      TaxRegime @default(NEW)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id])
}

enum TaxRegime {
  OLD
  NEW
}

model Payslip {
  id             String   @id @default(cuid())
  staffId        String
  month          Int      // 1-12
  year           Int
  workingDays    Int
  presentDays    Int
  leaveDays      Int
  absentDays     Int
  grossEarning   Decimal  @db.Decimal(10, 2)
  totalDeduction Decimal  @db.Decimal(10, 2)
  netPay         Decimal  @db.Decimal(10, 2)
  pfAmount       Decimal  @default(0) @db.Decimal(10, 2)
  esiAmount      Decimal  @default(0) @db.Decimal(10, 2)
  tdsAmount      Decimal  @default(0) @db.Decimal(10, 2)
  status         PayslipStatus @default(DRAFT)
  pdfUrl         String?
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, month, year])
}

enum PayslipStatus {
  DRAFT
  APPROVED
  PAID
}


// ============================================
// SECTION 10: STAFF ATTENDANCE & LEAVE
// ============================================

model StaffAttendance {
  id        String              @id @default(cuid())
  staffId   String
  date      DateTime
  status    AttendanceStatus
  inTime    DateTime?
  outTime   DateTime?
  source    AttendanceSource    @default(MANUAL)
  deviceId  String?
  remarks   String?
  createdAt DateTime            @default(now())

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  // Phase 5 (Performance): getDateAttendance (staffAttendance.
  // controller.ts) queries "every staff member's record for date X"
  // branch-wide - the existing @@unique([staffId, date]) is staffId-
  // first and doesn't help a date-only/date-first lookup.
  @@index([date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  ON_LEAVE
}

enum AttendanceSource {
  MANUAL
  CARD_TAP
  QR_CODE
  BIOMETRIC
}

// Declared non-working days for a branch (public holidays, festivals,
// school-specific closures) - so attendance reports/calendars can
// exclude these dates from the "should have been present" denominator
// instead of wrongly implying absence on a day nobody was expected in.
model Holiday {
  id       String   @id @default(cuid())
  branchId String
  date     DateTime
  name     String

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, date])
}

model LeaveType {
  id           String  @id @default(cuid())
  name         String  // CL, SL, EL, Maternity, Paternity, Comp Off
  code         String  @unique
  maxDays      Int     // annual quota
  carryForward Boolean @default(false)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())

  applications LeaveApplication[]
}

model LeaveApplication {
  id          String      @id @default(cuid())
  staffId     String
  leaveTypeId String
  fromDate    DateTime
  toDate      DateTime
  days        Int
  reason      String
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  remarks     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  staff     Staff     @relation(fields: [staffId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}


// ============================================
// SECTION 11: STUDENT ATTENDANCE (Manual + Card-Tap)
// ============================================

model StudentAttendance {
  id        String           @id @default(cuid())
  studentId String
  sectionId String
  date      DateTime
  status    AttendanceStatus
  inTime    DateTime?
  outTime   DateTime?
  source    AttendanceSource @default(MANUAL)
  deviceId  String?
  period    Int?             // null = day-wise, 1-8 = period-wise
  markedBy  String?          // teacher userId who marked
  createdAt DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([studentId, date, period])
  // Phase 5 (Performance): getClassAttendance (studentAttendance.
  // controller.ts) looks up "this section, this date" on every
  // attendance-marking page load; getStudentAttendanceHistory looks up
  // "this student, date range" for the parent/student portal view.
  @@index([sectionId, date])
  @@index([studentId, date])
}

model AttendanceDevice {
  id        String   @id @default(cuid())
  branchId  String
  deviceId  String   @unique
  name      String   // "Main Gate Reader", "Block A Entry"
  location  String?
  apiKey    String   @unique // for authenticating device requests
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
}

// ============================================
// SECTION 12: EXAM & MARKS
// ============================================

model Exam {
  id             String   @id @default(cuid())
  academicYearId String
  classId        String
  name           String   // "Unit Test 1", "Half Yearly", "Annual"
  type           ExamType
  startDate      DateTime?
  endDate        DateTime?
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])
  marks        Mark[]
  schedules    ExamSchedule[]
}

enum ExamType {
  UNIT_TEST
  HALF_YEARLY
  ANNUAL
  PRE_BOARD
  PRACTICAL
  INTERNAL
}


model Mark {
  id           String  @id @default(cuid())
  examId       String
  studentId    String
  subjectId    String
  maxMarks     Decimal @db.Decimal(5, 2)
  obtainedMarks Decimal @db.Decimal(5, 2)
  grade        String?
  remarks      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  exam    Exam    @relation(fields: [examId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([examId, studentId, subjectId])
}

model GradeSystem {
  id        String  @id @default(cuid())
  name      String  // "CBSE Grading", "Custom"
  minMarks  Decimal @db.Decimal(5, 2)
  maxMarks  Decimal @db.Decimal(5, 2)
  grade     String
  gradePoint Decimal? @db.Decimal(3, 1)
