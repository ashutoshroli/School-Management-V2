enum HostelType {
  BOYS
  GIRLS
}

model HostelFloor {
  id         String @id @default(cuid())
  buildingId String
  floorNo    Int
  
  building HostelBuilding @relation(fields: [buildingId], references: [id])
  rooms    HostelRoom[]
}

model HostelRoom {
  id        String   @id @default(cuid())
  floorId   String
  roomNo    String
  type      RoomType
  capacity  Int
  occupied  Int      @default(0)
  monthlyFee Decimal @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  floor       HostelFloor        @relation(fields: [floorId], references: [id])
  allocations HostelAllocation[]
