  @@unique([staffId, month, year])
}

enum PayslipStatus {
  DRAFT
  APPROVED
  PAID
}


// ============================================
// SECTION 10: STAFF ATTENDANCE & LEAVE
// ============================================

model StaffAttendance {
  id        String              @id @default(cuid())
  staffId   String
  date      DateTime
  status    AttendanceStatus
  inTime    DateTime?
  outTime   DateTime?
  source    AttendanceSource    @default(MANUAL)
  deviceId  String?
  remarks   String?
  createdAt DateTime            @default(now())

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  // Phase 5 (Performance): getDateAttendance (staffAttendance.
  // controller.ts) queries "every staff member's record for date X"
  // branch-wide - the existing @@unique([staffId, date]) is staffId-
  // first and doesn't help a date-only/date-first lookup.
  @@index([date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  ON_LEAVE
}

enum AttendanceSource {
  MANUAL
  CARD_TAP
  QR_CODE
  BIOMETRIC
}

// Declared non-working days for a branch (public holidays, festivals,
// school-specific closures) - so attendance reports/calendars can
// exclude these dates from the "should have been present" denominator
// instead of wrongly implying absence on a day nobody was expected in.
model Holiday {
  id       String   @id @default(cuid())
