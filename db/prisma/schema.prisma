// ============================================
// SECTION 22: AUDIT LOG
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "CREATE", "UPDATE", "DELETE"
  module    String   // "student", "payment", "attendance"
  entityId  String
