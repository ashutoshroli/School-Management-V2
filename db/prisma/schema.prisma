}

model Promotion {
  id             String   @id @default(cuid())
  studentId      String
  academicYearId String
  fromClassId    String
  toClassId      String?  // null = detained
  status         PromotionStatus
  remarks        String?
  createdAt      DateTime @default(now())

  student      Student      @relation(fields: [studentId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
}

enum PromotionStatus {
  PROMOTED
  DETAINED
  TC_ISSUED
}

// ============================================
// SECTION 12B: EXAM TIMETABLE + QUESTION PAPERS
// ============================================

// Per-subject exam schedule ("date sheet") - previously Exam only had
// ONE startDate/endDate for the whole exam with no per-subject
// date/time/room/duration at all. One row per subject sitting within
// an exam; maxMarks lives here (rather than only surfacing later when
// marks are entered) so the date sheet itself can show "Maths - 24 Mar,
// 10:00-13:00, 80 marks" up front.
model ExamSchedule {
  id              String   @id @default(cuid())
  examId          String
  subjectId       String
  examDate        DateTime
  startTime       String   // "10:00"
  endTime         String   // "13:00"
  durationMinutes Int
  roomId          String?  // optional: which room this paper is held in
  maxMarks        Decimal  @db.Decimal(5, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  exam           Exam                @relation(fields: [examId], references: [id])
  subject        Subject             @relation(fields: [subjectId], references: [id])
  room           SchoolRoom?         @relation(fields: [roomId], references: [id])
  questionPapers ExamQuestionPaper[]
  seatAllocations ExamSeatAllocation[]
  examAttendances ExamAttendance[]

  // One schedule entry per subject per exam - a subject can't be
  // examined twice within the same Exam.
  @@unique([examId, subjectId])
}

// Question paper uploaded by a teacher for one subject's exam sitting
// (PDF or DOCX). sectionId is optional - most classes use one shared
// paper (sectionId: null), but a class with multiple sections can have
// a different paper per section if needed (e.g. staggered timing).
// Upload access is teacher-scoped (see canTeacherUploadQuestionPaper in
// utils/teacherAccess.ts) - a TEACHER may only upload for a subject
// they actually teach (school-wide default OR class-specific
// SubjectTeacher assignment); ADMIN roles are unrestricted.
model ExamQuestionPaper {
  id             String   @id @default(cuid())
  examScheduleId String
  sectionId      String?
  fileUrl        String
  fileName       String
  uploadedBy     String   // staff userId
  createdAt      DateTime @default(now())

  examSchedule ExamSchedule @relation(fields: [examScheduleId], references: [id])
  section      Section?     @relation(fields: [sectionId], references: [id])
}

// Room-wise seat allocation for one exam sitting (Phase 2) - one row
// per seated student. Declared here (rather than deferred to Phase 2's
// migration) so the FK from ExamSchedule above is complete in this
// migration; the generator endpoints themselves land in Phase 2.
model ExamSeatAllocation {
  id             String  @id @default(cuid())
  examScheduleId String
  roomId         String
  studentId      String
  seatNo         Int
  createdAt      DateTime @default(now())

  examSchedule ExamSchedule @relation(fields: [examScheduleId], references: [id])
  room         SchoolRoom   @relation(fields: [roomId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])

  @@unique([examScheduleId, studentId])
  @@unique([examScheduleId, roomId, seatNo])
}

// Per-sitting exam attendance (Phase 3) - deliberately separate from
// StudentAttendance (daily roll call); a student can be present for
// daily attendance but absent for one specific paper, or vice versa.
// Declared here alongside its sibling exam models for the same
// single-migration reason as ExamSeatAllocation above.
model ExamAttendance {
  id             String              @id @default(cuid())
  examScheduleId String
  studentId      String
  status         ExamAttendanceStatus
  markedBy       String?             // staff userId
  remarks        String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  examSchedule ExamSchedule @relation(fields: [examScheduleId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])

  @@unique([examScheduleId, studentId])
}

enum ExamAttendanceStatus {
  PRESENT
  ABSENT
  UNFAIR_MEANS
  LATE
}

// ============================================
// SECTION 13: TIMETABLE + PERIOD CONFIG
// ============================================

// Admin-configurable list of periods per branch (replaces the previous
// un-enforced "1-8" convention on TimetableSlot.period). Each branch
// can define 6, 7, 8, or 9 periods with their exact start/end times -
// the attendance marking UI's period picker shows this list, and the
// TimetableSlot editor should use it too for consistency.
model PeriodConfig {
  id        String @id @default(cuid())
  branchId  String
  periodNo  Int
  label     String? // "Period 1", "Lunch Break" (for display only)
  startTime String  // "09:00"
  endTime   String  // "09:45"
  isBreak   Boolean @default(false) // true = not attendance-markable

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, periodNo])
}

model Timetable {
  id             String   @id @default(cuid())
  academicYearId String
  classId        String
  sectionId      String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYear AcademicYear  @relation(fields: [academicYearId], references: [id])
  class        Class         @relation(fields: [classId], references: [id])
  section      Section       @relation(fields: [sectionId], references: [id])
  slots        TimetableSlot[]
}


model TimetableSlot {
  id          String  @id @default(cuid())
  timetableId String
  day         DayOfWeek
  period      Int     // 1, 2, 3... 8
  subjectId   String?
  teacherId   String?
  startTime   String  // "09:00"
  endTime     String  // "09:45"
  isBreak     Boolean @default(false)

  timetable Timetable @relation(fields: [timetableId], references: [id])
  teacher   Staff?    @relation(fields: [teacherId], references: [id])

  @@unique([timetableId, day, period])
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

// ============================================
