model StudentAttendance {
  id        String           @id @default(cuid())
  studentId String
  sectionId String
  date      DateTime
  status    AttendanceStatus
  inTime    DateTime?
  outTime   DateTime?
  source    AttendanceSource @default(MANUAL)
  deviceId  String?
  period    Int?             // null = day-wise, 1-8 = period-wise
  markedBy  String?          // teacher userId who marked
  createdAt DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([studentId, date, period])
  // Phase 5 (Performance): getClassAttendance (studentAttendance.
